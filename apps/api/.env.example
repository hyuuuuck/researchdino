RESEARCHDINO_AGENT_RUNTIME=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=240
OLLAMA_READER_MAX_CHARS=120000

# Role-specific local Ollama models. Override any role independently.
OLLAMA_SEARCH_MODEL=qwen3.5:latest
OLLAMA_READER_MODEL=qwen3.5:latest
OLLAMA_CRITIC_MODEL=qwen3.5:latest
OLLAMA_LIBRARIAN_MODEL=qwen3.5:latest
OLLAMA_STRATEGIST_MODEL=qwen3.5:latest
OLLAMA_EXPERIMENT_MODEL=qwen3.5:latest
OLLAMA_COORDINATOR_MODEL=qwen3.5:latest
OLLAMA_LEADER_MODEL=qwen3.5:latest
OLLAMA_WRITER_MODEL=qwen3.5:latest
