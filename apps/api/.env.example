RESEARCHDINO_AGENT_RUNTIME=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=240
OLLAMA_READER_MAX_CHARS=120000

# Role-specific Ollama Cloud models. Override any role independently.
OLLAMA_SEARCH_MODEL=gpt-oss:20b-cloud
OLLAMA_READER_MODEL=qwen3.5:cloud
OLLAMA_CRITIC_MODEL=gpt-oss:120b-cloud
OLLAMA_LIBRARIAN_MODEL=gpt-oss:20b-cloud
OLLAMA_STRATEGIST_MODEL=nemotron-3-super:cloud
OLLAMA_EXPERIMENT_MODEL=qwen3.5:cloud
OLLAMA_COORDINATOR_MODEL=nemotron-3-super:cloud
OLLAMA_LEADER_MODEL=gpt-oss:120b-cloud
OLLAMA_WRITER_MODEL=qwen3.5:cloud

# Direct ollama.com access is optional. Never commit a real key.
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_API_KEY=
